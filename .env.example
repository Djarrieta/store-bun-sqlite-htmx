# --- App ---
PORT=4000
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:4000

# Dev-only login (F8). Set to 1 to enable /dev-login without Google OAuth.
DEV_LOGIN=1

# --- Auth / OAuth (Google) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:4000/auth/callback
ADMIN_ALLOWLIST=admin@example.com

# --- LLM (DeepSeek, OpenAI-compatible) ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Pagos (v1: Nequi manual) ---
NEQUI_NUMBER=300 000 0000
NEQUI_QR_URL=

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Chat API (canal server-to-server) ---
CHAT_API_SECRET=
