# --- App ---
PORT=4010
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:4010

# Dev-only login (F8). Set to 1 to enable /dev-login without Google OAuth.
DEV_LOGIN=1

# --- Auth / OAuth (Google) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:4010/auth/callback
ADMIN_ALLOWLIST=admin@example.com

# --- LLM (DeepSeek, OpenAI, Ollama) ---
LLM_PROVIDER=deepseek
# LLM_API_KEY=
# LLM_MODEL=
# LLM_BASE_URL=

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Pagos (v1: Nequi manual) ---
NEQUI_NUMBER=300 000 0000
NEQUI_QR_URL=

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Chat API (canal server-to-server) ---
CHAT_API_SECRET=
